# ─── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Railway, Supabase, or any Postgres)
DATABASE_URL=postgresql://user:password@host:5432/nichebriefs_hvac

# ─── Auth (NextAuth v5 / Auth.js) ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Your deployment URL — required for auth callbacks in production
# On Vercel this is typically set automatically, but set it explicitly to be safe
AUTH_URL=https://your-app.vercel.app

# Optional: Google OAuth provider (leave blank to use credentials-only auth)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Stripe ─────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Create a product + price in Stripe and paste the price ID here
STRIPE_PRICE_ID=price_...

# Get this from Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
